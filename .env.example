# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=hcms
POSTGRES_PASSWORD=hcmspassword
POSTGRES_DB=hcms

# ── Backend ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
ENVIRONMENT=development

# ── AWS / LocalStack ───────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Leave blank to use real AWS; set to http://localhost:4566 for LocalStack
LOCALSTACK_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=hcms-documents
USE_SECRETS_MANAGER=false
# Secret name used when USE_SECRETS_MANAGER=true
DB_SECRET_NAME=hcms/db/credentials

# ── LocalStack (optional auth token for Pro features) ─────────────────────────
LOCALSTACK_AUTH_TOKEN=
